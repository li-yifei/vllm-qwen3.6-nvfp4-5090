# Hugging Face API token (required for gated models)
HF_TOKEN=hf_your_token_here
# Path to local Hugging Face cache directory
HF_CACHE=/home/your_username/.cache/huggingface
# Path to local vLLM AOT compilation cache
VLLM_CACHE=/home/your_username/.cache/vllm
# Model to serve (default: lyf's NVFP4 quantization of official Qwen3.6-27B)
MODEL_ID=lyf/Qwen3.6-27B-NVFP4
# Container name
CONTAINER_NAME=qwen3.6-nvfp4
# vLLM serving port
PORT=8000
# Max context length
MAX_MODEL_LEN=262144
# GPU memory utilization (0.0-1.0)
GPU_MEMORY_UTILIZATION=0.8
# Max concurrent sequences
MAX_NUM_SEQS=4
# Max tokens per batch
MAX_NUM_BATCHED_TOKENS=4096
# KV cache precision
KV_CACHE_DTYPE=fp8
# NVFP4 GEMM backend
NVFP4_BACKEND=marlin
# Reasoning parser
REASONING_PARSER=qwen3
# Tool call parser
TOOL_CALL_PARSER=qwen3_coder
